// Prisma Schema — Smart Dining Assistant
// Using PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── MenuItem ─────────────────────────────────────────────────
model MenuItem {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(120)
  category    String   @db.VarChar(50)
  price       Decimal  @db.Decimal(10, 2)
  description String   @db.Text
  imageUrl    String?  @map("image_url") @db.Text
  tags        String[]
  allergens   String[]
  available   Boolean  @default(true)
  popularScore Float   @default(0) @map("popular_score")
  isVeg       Boolean  @default(true) @map("is_veg")
  isSpicy     Boolean  @default(false) @map("is_spicy")
  calories    Int?
  prepTime    Int?     @map("prep_time") // minutes
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  cartItems         CartItem[]
  orderItems        OrderItem[]
  // Self-referential many-to-many for complementary items
  complementsFrom   Complement[] @relation("ComplementFrom")
  complementsTo     Complement[] @relation("ComplementTo")

  @@map("menu_items")
}

// Self-referential M:M for complementary menu items
model Complement {
  id     String @id @default(uuid())
  fromId String @map("from_id")
  toId   String @map("to_id")

  from MenuItem @relation("ComplementFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   MenuItem @relation("ComplementTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
  @@map("complements")
}

// ─── Session ──────────────────────────────────────────────────
model Session {
  id                  String        @id @default(uuid())
  tableId             String        @map("table_id") @db.VarChar(20)
  status              SessionStatus @default(ACTIVE)
  preferences         Json          @default("{}")
  conversationSummary String?       @map("conversation_summary") @db.Text
  guestCount          Int           @default(1) @map("guest_count")
  createdAt           DateTime      @default(now()) @map("created_at")
  expiresAt           DateTime      @map("expires_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  // Relations
  cartItems CartItem[]
  orders    Order[]
  messages  Message[]

  @@map("sessions")
}

enum SessionStatus {
  ACTIVE
  ORDERED
  CLOSED
}

// ─── CartItem ─────────────────────────────────────────────────
model CartItem {
  id                  String   @id @default(uuid())
  sessionId           String   @map("session_id")
  menuItemId          String   @map("menu_item_id")
  quantity            Int      @default(1)
  specialInstructions String?  @map("special_instructions") @db.Text
  addedBy             String   @default("Guest") @map("added_by") @db.VarChar(50)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  session  Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("cart_items")
}

// ─── Order ────────────────────────────────────────────────────
model Order {
  id              String      @id @default(uuid())
  sessionId       String      @map("session_id")
  customerName    String      @map("customer_name") @db.VarChar(100)
  customerPhone   String      @map("customer_phone") @db.VarChar(15)
  status          OrderStatus @default(PENDING)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(10, 2)
  taxAmount       Decimal     @map("tax_amount") @db.Decimal(10, 2)
  estimatedWait   Int?        @map("estimated_wait") // minutes
  specialNotes    String?     @map("special_notes") @db.Text
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  session    Session     @relation(fields: [sessionId], references: [id])
  orderItems OrderItem[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

// ─── OrderItem ────────────────────────────────────────────────
model OrderItem {
  id                  String   @id @default(uuid())
  orderId             String   @map("order_id")
  menuItemId          String   @map("menu_item_id")
  quantity            Int      @default(1)
  unitPrice           Decimal  @map("unit_price") @db.Decimal(10, 2)
  specialInstructions String?  @map("special_instructions") @db.Text
  createdAt           DateTime @default(now()) @map("created_at")

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

// ─── Message (AI Conversation History) ────────────────────────
model Message {
  id        String      @id @default(uuid())
  sessionId String      @map("session_id")
  role      MessageRole
  content   String      @db.Text
  metadata  Json        @default("{}") // stores suggestions, itemIds, etc.
  createdAt DateTime    @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ─── OTP ──────────────────────────────────────────────────────
model OtpVerification {
  id        String   @id @default(uuid())
  phone     String   @db.VarChar(15)
  otpHash   String   @map("otp_hash") @db.VarChar(128)
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone])
  @@map("otp_verifications")
}
